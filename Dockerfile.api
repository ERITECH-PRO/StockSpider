FROM node:20-alpine

WORKDIR /app

# Installer dépendances uniquement nécessaires au serveur
COPY package*.json ./

# Installer uniquement les deps de prod pour l'image runtime
RUN npm ci --omit=dev

# Copier le code serveur
COPY server ./server

# Exposer le port API
EXPOSE 3002

# Variables d'env (peuvent être surchargées par docker-compose)
ENV NODE_ENV=production

CMD ["node", "server/server.cjs"]


